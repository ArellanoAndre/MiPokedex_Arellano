<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- HEADER -->


    <!-- CARD BLANCA -->
    <!-- CARD BLANCA -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardInfo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="-40dp"

        app:cardCornerRadius="34dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardUseCompatPadding="false"

        app:layout_constraintTop_toBottomOf="@id/ivHeaderBg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="36dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:background="#CECECE">

            <!-- CHIP -->
            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:text="Eléctrico"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"

                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- GUIDELINE -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guidelineMid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.54042554" />

            <!-- ALTURA -->
            <TextView
                android:id="@+id/tvAlturaLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="100dp"
                android:text="Altura"
                android:textColor="#C62828"
                android:textSize="26sp"

                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvType" />

            <TextView
                android:id="@+id/tvAlturaValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="0,4m"
                android:textColor="#555555"

                android:textSize="26sp"
                app:layout_constraintBaseline_toBaselineOf="@id/tvAlturaLabel"
                app:layout_constraintStart_toEndOf="@id/tvAlturaLabel" />

            <!-- PESO -->
            <TextView
                android:id="@+id/tvPesoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Peso"
                android:textColor="#C62828"
                android:textSize="26sp"

                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvAlturaLabel" />

            <TextView
                android:id="@+id/tvPesoValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="6,0kg"
                android:textColor="#555555"

                android:textSize="26sp"
                app:layout_constraintBaseline_toBaselineOf="@id/tvPesoLabel"
                app:layout_constraintStart_toEndOf="@id/tvPesoLabel" />

            <!-- HABILIDAD -->
            <TextView
                android:id="@+id/tvHabLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="Habilidad"
                android:textColor="#C62828"
                android:textSize="26sp"

                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/guidelineMid"
                app:layout_constraintTop_toTopOf="@id/tvAlturaLabel" />

            <TextView
                android:id="@+id/tvHabValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Elec. Estática"
                android:textColor="#555555"

                android:textSize="26sp"
                app:layout_constraintStart_toStartOf="@id/tvHabLabel"
                app:layout_constraintTop_toBottomOf="@id/tvHabLabel" />

            <!-- DESCRIPCIÓN -->
            <TextView
                android:id="@+id/tvDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="Cuando se enfada, este Pokémon descarga la energía que almacena en el interior de las bolsas de las mejillas."
                android:textColor="#555555"

                android:textSize="22sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"

                app:layout_constraintTop_toBottomOf="@id/tvPesoLabel" />

            <ImageView
                android:id="@+id/ivNextPokemon"
                android:layout_width="90dp"
                android:layout_height="90dp"

                android:layout_marginTop="100dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/raich"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/ivPrevPokemon"
                app:layout_constraintTop_toBottomOf="@+id/tvDesc"
                app:layout_constraintVertical_bias="0.0" />

            <ImageView
                android:id="@+id/ivPrevPokemon"
                android:layout_width="90dp"
                android:layout_height="90dp"

                android:layout_marginStart="24dp"
                android:layout_marginTop="100dp"
                android:layout_marginBottom="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/arbok"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/ivNextPokemon"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDesc"
                app:layout_constraintVertical_bias="0.0" />

            <TextView
                android:id="@+id/tvNextName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"

                android:layout_marginEnd="277dp"
                android:gravity="center"
                android:text="Raichu N.º 0026"
                android:textColor="#555555"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ivNextPokemon"
                app:layout_constraintVertical_bias="0.0" />

            <TextView
                android:id="@+id/tvPrevName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"

                android:layout_marginEnd="24dp"
                android:gravity="center"
                android:text="Arbok N.º 0024"
                android:textColor="#555555"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ivPrevPokemon"
                app:layout_constraintVertical_bias="0.0" />

            <ImageView
                android:id="@+id/btnPrev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="360dp"
                android:layout_marginTop="8dp"

                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#121010"
                android:src="@drawable/flechaizq"
                android:tint="@android:color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.862"
                app:layout_constraintStart_toEndOf="@+id/btnNext"
                app:layout_constraintTop_toBottomOf="@+id/tvPrevName"
                app:layout_constraintVertical_bias="0.0" />

            <ImageView
                android:id="@+id/btnNext"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"

                android:layout_marginEnd="375dp"
                android:layout_marginBottom="47dp"
                android:background="@drawable/bg_circle"
                android:src="@drawable/flechaderecha"
                android:tint="@android:color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvNextName"
                app:layout_constraintVertical_bias="0.0" />

        </androidx.constraintlayout.widget.ConstraintLayout>
        <!-- ARBOK -->

        <!-- RAICHU -->

    </androidx.cardview.widget.CardView>

    <!-- pikachuu  -->
    <ImageView
        android:id="@+id/ivPokemon"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="-130dp"
        android:elevation="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ivpokemon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivHeaderBg" />

    <ImageView
        android:id="@+id/ivHeaderBg"
        android:layout_width="0dp"
        android:layout_height="320dp"
        android:scaleType="centerCrop"
        android:src="@drawable/headerimag"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="109dp"
        android:layout_height="32dp"
        android:layout_marginTop="35dp"
        android:text="Pikachu"
        android:textColor="@android:color/white"

        android:textSize="24sp"
        android:textStyle="bold"

        app:layout_constraintBottom_toTopOf="@+id/tvNumber"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.099"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivHeaderBg" />

    <TextView
        android:id="@+id/tvNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="#025"
        android:textColor="#333333"
        android:textSize="28sp"

        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/tvName"
        app:layout_constraintTop_toBottomOf="@id/tvName" />

    <ImageView
        android:id="@+id/ivstar"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"

        android:layout_marginEnd="16dp"
        android:elevation="10dp"

        android:src="@drawable/ivstar"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivHeaderBg" />

    <!-- TEXTO IZQUIERDA -->

    <!-- TEXTO DERECHA -->
    <!-- BOTÓN IZQUIERDO -->

    <!-- BOTÓN DERECHO -->


</androidx.constraintlayout.widget.ConstraintLayout>
